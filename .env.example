# Copy this file to .env and fill in all values before running.
# NEVER commit .env to git. Generate strong random secrets for production.

# ===== DATABASE =====
# Generate a strong password: node -e "require('crypto').randomBytes(32).toString('hex')" | then set as DB password
DATABASE_URL=postgresql://secureops:CHANGE_ME_STRONG_PASSWORD@localhost:5432/secureops

# ===== REDIS =====
REDIS_URL=redis://:CHANGE_ME_STRONG_PASSWORD@localhost:6379

# ===== AUTH =====
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHAR_MIN_RANDOM_HEX
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_MIN_RANDOM_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== FILE STORAGE (AWS S3 / MinIO) =====
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME_STRONG_PASSWORD
AWS_REGION=ap-south-1
AWS_S3_BUCKET=secureops-files
# S3_ENDPOINT=http://localhost:9000  # uncomment for local MinIO

# ===== GOOGLE MAPS =====
GOOGLE_MAPS_API_KEY=

# ===== FIREBASE (Push Notifications) =====
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ===== SMS - MSG91 =====
MSG91_AUTH_KEY=
MSG91_SENDER_ID=SECOPS
MSG91_TEMPLATE_OTP=

# ===== WHATSAPP - Twilio =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155552671

# ===== EMAIL - Resend =====
RESEND_API_KEY=

# ===== PAYMENTS - Razorpay =====
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ===== APP URLS =====
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ===== SUPER ADMIN =====
SUPER_ADMIN_EMAIL=admin@secureops.in
# Generate: node -e "require('crypto').randomBytes(20).toString('hex')"
SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ===== DOCKER SERVICES (used by infra/docker-compose.yml via infra/.env) =====
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ===== ENVIRONMENT =====
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
